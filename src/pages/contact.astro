---
import '../styles/global.css';
import Layout from '../components/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';

const title = 'Contact Amit Upadhyay | AI Architecture Advisory';
const description = 'Reach out to Amit Upadhyay for AI architecture advisory, system design discussions, or technical collaboration.';

const contactLinks = [
  {
    label: 'Email',
    value: 'hello@amitupadhyay.com',
    href: 'mailto:hello@amitupadhyay.com',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  },
  {
    label: 'LinkedIn',
    value: 'linkedin.com/in/upadhyaya-amit',
    href: 'https://www.linkedin.com/in/upadhyaya-amit/',
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    label: 'GitHub',
    value: 'github.com/UpadhyayAmit',
    href: 'https://github.com/UpadhyayAmit',
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>`,
  },
  {
    label: 'Blog',
    value: 'aiwisdom.dev',
    href: 'https://aiwisdom.dev',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>`,
  },
];

const openTo = [
  {
    title: 'AI Architecture Advisory',
    description: 'Advising on RAG pipelines, agent systems, and production AI architecture on Azure.',
  },
  {
    title: 'Technical Writing & Speaking',
    description: 'Technical essays, conference talks, and workshop sessions on AI engineering.',
  },
  {
    title: 'Senior AI Engineering Opportunities',
    description: 'Open to the right full-time role — AI-first teams building systems that matter.',
  },
  {
    title: 'Code & Architecture Reviews',
    description: 'Deep review of AI system design, .NET backends, and cloud architecture.',
  },
];
---

<Layout title={title} description={description}>
  <Navbar slot="navbar" />

  <!-- Hero -->
  <section class="relative pt-32 pb-16 md:pt-40 md:pb-24 overflow-hidden">
    <div class="absolute inset-0 bg-grid opacity-30"></div>
    <div class="absolute top-20 left-1/3 w-96 h-96 bg-accent/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 right-1/4 w-64 h-64 bg-purple-500/5 rounded-full blur-3xl"></div>

    <div class="relative max-w-container mx-auto px-6">
      <div class="max-w-3xl">
        <div class="status-badge mb-6 animate-fade-in">
          <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
          Open to Advisory
        </div>
        <h1 class="text-h1-mobile md:text-h1 text-primary animate-fade-in-up">
          Let's build something <span class="text-accent">intelligent.</span>
        </h1>
        <p class="mt-6 text-body-lg text-secondary max-w-xl animate-fade-in-up" style="animation-delay: 0.2s;">
          If your team is building AI systems on Azure and needs a production-tested perspective on architecture, .NET design, or scaling beyond demos — let's talk.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact + Open To -->
  <section class="pb-24 md:pb-32">
    <div class="max-w-container mx-auto px-6">
      <div class="grid lg:grid-cols-5 gap-8">
        <!-- Contact Links -->
        <div class="lg:col-span-2 space-y-4 reveal">
          <h2 class="text-h3 text-primary mb-6">Get in Touch</h2>
          {contactLinks.map((link, i) => (
            <a
              href={link.href}
              target={link.href.startsWith('mailto') ? undefined : '_blank'}
              rel={link.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
              class={`glow-card rounded-xl p-5 flex items-center gap-4 group reveal reveal-delay-${(i % 4) + 1}`}
            >
              <div class="w-10 h-10 rounded-lg bg-accent/10 text-accent flex items-center justify-center group-hover:bg-accent/20 transition-colors" set:html={link.icon} />
              <div>
                <p class="text-xs text-muted uppercase tracking-wider">{link.label}</p>
                <p class="text-sm font-medium text-primary group-hover:text-accent transition-colors">{link.value}</p>
              </div>
              <svg class="w-4 h-4 text-muted ml-auto opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          ))}
        </div>

        <!-- Open To -->
        <div class="lg:col-span-3 reveal reveal-delay-2">
          <h2 class="text-h3 text-primary mb-6">What I'm Open To</h2>
          <div class="grid sm:grid-cols-2 gap-4">
            {openTo.map((item, i) => (
              <div class={`glow-card rounded-xl p-6 reveal reveal-delay-${(i % 4) + 1}`}>
                <div class="w-8 h-8 rounded-lg bg-accent/10 text-accent flex items-center justify-center text-sm font-bold mb-3">
                  {String(i + 1).padStart(2, '0')}
                </div>
                <h3 class="text-base font-semibold text-primary">{item.title}</h3>
                <p class="mt-2 text-sm text-muted leading-relaxed">{item.description}</p>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Bottom CTA -->
      <div class="mt-16 text-center reveal">
        <p class="text-muted text-sm">Prefer email?</p>
        <a href="mailto:hello@amitupadhyay.com" class="mt-2 inline-block text-2xl md:text-3xl font-bold text-accent hover:text-accent-hover transition-colors">
          hello@amitupadhyay.com
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) entry.target.classList.add('visible');
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
  );
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
