      <div class="mt-14">
        {capabilities.map((cap, i) => (
          <div class={`capability-row reveal reveal-delay-${i + 1}`}>
            <!-- Left: number + title + description -->
            <div class="flex items-start gap-5 flex-1 min-w-0">
              <span class="font-mono text-sm text-accent/60 tabular-nums mt-0.5 flex-shrink-0">{cap.number}</span>
              <div class="min-w-0">
                <h3 class="text-lg font-semibold font-heading text-primary">{cap.title}</h3>
                <p class="mt-1.5 text-sm text-muted leading-relaxed max-w-lg">{cap.description}</p>
              </div>
            </div>
            <!-- Right: skill tags -->
            <div class="capability-tags flex-shrink-0 max-w-xs hidden md:flex">
              {cap.tags.map((tag) => (
                <span class="capability-tag">{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- Mobile tags fallback -->
      <div class="mt-6 md:hidden space-y-3 reveal reveal-delay-3">
        {capabilities.map((cap) => (
          <div class="flex flex-wrap gap-2">
            {cap.tags.map((tag) => (
              <span class="capability-tag">{tag}</span>
            ))}
          </div>
        ))}
      </div>
    </div>
  </section>

