---

<Layout title={title} description={description}>
  <Navbar slot="navbar" />

  <!-- Cursor glow -->
  <div id="cursor-glow" class="cursor-glow hidden lg:block"></div>

  <!-- ============================================================ -->
  <!-- HERO SECTION                                                 -->
  <!-- ============================================================ -->
  <section class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden text-center">
    <!-- Background layers -->
    <div class="absolute inset-0 bg-grid opacity-25"></div>
    <div class="absolute inset-0 glow-radial-teal"></div>
    <div class="absolute top-1/3 left-1/4 w-[500px] h-[500px] rounded-full bg-teal-500/[0.03] blur-[140px] pointer-events-none"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] rounded-full bg-indigo-500/[0.03] blur-[120px] pointer-events-none"></div>

    <div class="relative max-w-container mx-auto px-6 pt-28 pb-20 flex flex-col items-center">

      <!-- Avatar — static gradient ring, 112px photo -->
      <div class="avatar-glow-ring mb-5 animate-fade-in" style="animation-delay: 0.1s;">
        <img src="/profile.png" alt="Amit Upadhyay" class="w-28 h-28 rounded-full object-cover object-top shadow-xl" />
      </div>

      <!-- Availability badge -->
      <div class="hero-badge mb-8 animate-fade-in" style="animation-delay: 0.25s;">
        <span class="relative flex h-2.5 w-2.5">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green-400"></span>
        </span>
        Open to AI Architecture Advisory
      </div>

      <!-- Heading -->
      <h1 class="text-h1-mobile md:text-h1 text-primary font-heading tracking-tighter animate-fade-in-up max-w-4xl" style="animation-delay: 0.35s;">
        Designing Production-Grade<br class="hidden lg:block" />
        <span class="text-accent">AI Systems</span> <span class="text-secondary/70">with Azure & .NET</span>
      </h1>

      <!-- Bio -->
      <p class="mt-6 text-body-lg text-secondary max-w-xl leading-relaxed animate-fade-in-up" style="animation-delay: 0.45s;">
        AI Systems Architect building production-grade AI systems on Azure and .NET — backed by 14 years of engineering experience. Not demos. Production systems that run at scale — and the lessons documented openly at aiwisdom.dev.
      </p>

      <!-- CTAs -->
      <div class="mt-10 flex flex-wrap items-center justify-center gap-4 animate-fade-in-up" style="animation-delay: 0.55s;">
        <Button href="/projects" variant="primary" size="lg">
          View Projects
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </Button>
        <Button href="https://aiwisdom.dev" variant="secondary" size="lg" external>
          Read AI Articles
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
        </Button>
      </div>

      <!-- Floating tech icon bubbles -->
      <div class="mt-12 flex flex-wrap items-center justify-center gap-3 animate-fade-in-up" style="animation-delay: 0.65s;">
        {[
