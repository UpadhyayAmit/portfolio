---
import '../styles/global.css';
import Layout from '../components/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const title = 'AI Projects by Amit Upadhyay | Azure OpenAI & .NET';
const description = 'Projects by Amit Upadhyay: TowerAssist (Flutter + Firebase), AI Study Planner (React Native + Groq), LegalAI (Flutter + Google Gemini), and the Panchatantra Algorithm Series.';

const projects = [
  {
    title: 'BazaarPulse',
    tagline: 'Indian market intelligence platform with real-time NSE data.',
    image: '/bazaarpulse.png',
    stack: ['Next.js', 'Supabase', 'Redis', 'TypeScript'],
    description:
      'A comprehensive market platform featuring real-time NSE data, stock screeners, and analytics. Built with a resilient browser-like NSE client utilizing cookie management and Upstash Redis for intelligent caching during market hours. Integrates Supabase for portfolio and watchlist tracking with Row Level Security.',
    lesson: 'Efficient caching and robust error handling are vital for public APIs.',
    category: 'Fintech Platform',
    metrics: [
      { label: 'Data', value: 'Real-Time NSE' },
      { label: 'Cache', value: 'Redis (Upstash)' },
    ],
    live: 'https://bazaarpulse.app',
    github: 'https://github.com/UpadhyayAmit/bazaarpulse'
  },
  {
    title: 'PyAnimate',
    tagline: 'Interactive browser-based Python algorithm learning playground.',
    image: '/pyanimate.png',
    stack: ['Next.js', 'Pyodide', 'Monaco', 'Framer Motion'],
    description:
      'A fully client-side Python execution environment built with Pyodide (WebAssembly). Enables users to step through algorithm executions line-by-line with interactive visualizations and Big O complexity charts. Integrates Monaco Editor for professional code editing.',
    lesson: 'WebAssembly unlocks powerful client-side capabilities without server costs.',
    category: 'EdTech Tool',
    metrics: [
      { label: 'Runtime', value: 'Pyodide WASM' },
      { label: 'Lessons', value: '50 Interactive' },
    ],
    live: 'https://pyanimate.com',
    github: 'https://github.com/UpadhyayAmit/PyAnimate'
  },
  {
    title: 'How Things Work',
    tagline: 'Visual encyclopedia explaining internal technologies.',
    image: '/howthingswork.png',
    stack: ['Next.js', 'React Flow', 'Framer Motion', 'Zustand'],
    description:
      'An interactive platform that uses animated diagrams, step-through visualizations, and interactive code editors to explain the internals of technologies like React Fiber, Azure Functions, and .NET Garbage Collection.',
    lesson: 'Complex technical concepts are best taught through interactive visual traversal.',
    category: 'Education Platform',
    metrics: [
      { label: 'Visuals', value: 'React Flow' },
      { label: 'Content', value: 'MDX' },
    ],
    live: 'https://howthingswork.live',
    github: 'https://github.com/UpadhyayAmit/howthingswork'
  },
  {
    title: 'SutraFlow',
    tagline: 'Interactive Vedic Mathematics learning platform.',
    image: '/sutraflow.png',
    stack: ['Next.js', 'KaTeX', 'Framer Motion', 'Vitest'],
    description:
      'A platform to teach students mental math techniques using Vedic Mathematics. Guides learners through Watch, Guided Practice, and Mental Math modes with step-by-step animations and mathematically validated problem generation.',
    lesson: 'Teaching algorithms requires deep conceptual proofs alongside practice.',
    category: 'EdTech Tool',
    metrics: [
      { label: 'Math', value: 'KaTeX Rendering' },
      { label: 'Testing', value: '100% Coverage' },
    ],
    live: 'https://sutraflow.app',
    github: 'https://github.com/UpadhyayAmit/SutraFlow'
  },
  {
    title: 'AI Wisdom',
    tagline: 'Technical writing platform for AI Architecture and Engineering.',
    image: '/aiwisdom.png',
    stack: ['Astro', 'Tailwind CSS', 'MDX', 'Vercel'],
    description:
      'A high-performance static site dedicated to essays, guides, and case studies on building real-world AI systems. Designed for readability with an emphasis on production lessons rather than theory. Uses Astro for near-instant page loads.',
    lesson: 'Content platforms must prioritize typography, reading experience, and zero-JS overhead.',
    category: 'Blog Platform',
    metrics: [
      { label: 'Performance', value: '100 Lighthouse' },
      { label: 'Architecture', value: 'Static Gen' },
    ],
    live: 'https://aiwisdom.dev',
    github: 'https://github.com/UpadhyayAmit/aiwisdom.dev'
  }
];
---

<Layout title={title} description={description}>
  <Navbar slot="navbar" />

  <!-- Heading -->
  <section class="relative pt-32 pb-16 md:pt-40 md:pb-24 overflow-hidden">
    <div class="absolute inset-0 bg-grid opacity-30"></div>
    <div class="absolute top-20 left-1/4 w-96 h-96 bg-accent/5 rounded-full blur-3xl"></div>

    <div class="relative max-w-container mx-auto px-6">
      <div class="max-w-3xl">
        <p class="text-xs font-medium text-accent uppercase tracking-widest mb-3 animate-fade-in">Portfolio</p>
        <h1 class="text-h1-mobile md:text-h1 text-primary animate-fade-in-up">
          Selected <span class="text-accent">Work</span>
        </h1>
        <p class="mt-6 text-body-lg text-secondary animate-fade-in-up" style="animation-delay: 0.2s;">
          Production-grade AI systems, tools, and experiments.
        </p>
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section class="pb-24 md:pb-32">
    <div class="max-w-container mx-auto px-6 space-y-8">
      {projects.map((project, i) => (
        <article class={`glow-card rounded-2xl overflow-hidden reveal reveal-delay-${(i % 4) + 1}`}>
          <!-- Image -->
          <div class="w-full h-48 md:h-80 overflow-hidden bg-background/50 border-b border-border/50">
            <img src={project.image} alt={project.title} class="w-full h-full object-cover object-top hover:scale-105 transition-transform duration-700" />
          </div>

          <!-- Header bar -->
          <div class="px-8 md:px-10 pt-8 flex items-center justify-between">
            <span class="px-3 py-1 rounded-lg text-xs font-medium bg-accent/10 text-accent border border-accent/20">
              {project.category}
            </span>
            <div class="flex items-center gap-4">
              {project.metrics.map((m) => (
                <div class="text-right">
                  <p class="text-xs text-muted">{m.label}</p>
                  <p class="text-sm font-medium text-primary">{m.value}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- Content -->
          <div class="p-8 md:p-10">
            {project.live ? (
              <a href={project.live} target="_blank" rel="noopener noreferrer" class="group/title inline-flex items-center gap-2">
                <h2 class="text-h2 text-primary group-hover/title:text-accent transition-colors">{project.title}</h2>
                <svg class="w-6 h-6 text-muted group-hover/title:text-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
              </a>
            ) : (
              <h2 class="text-h2 text-primary">{project.title}</h2>
            )}
            <p class="mt-2 text-body-lg text-secondary">{project.tagline}</p>

            <p class="mt-6 text-body text-muted leading-relaxed max-w-2xl">
              {project.description}
            </p>

            <!-- Stack & Lesson -->
            <div class="mt-8 pt-6 border-t border-border/50 flex flex-col md:flex-row md:items-center justify-between gap-4">
              <div class="flex flex-wrap gap-2">
                {project.stack.map((tech) => (
                  <span class="pill text-xs">{tech}</span>
                ))}
              </div>
              <p class="text-sm text-muted">
                <span class="text-accent font-medium">Lesson:</span> {project.lesson}
              </p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) entry.target.classList.add('visible');
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
  );
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
