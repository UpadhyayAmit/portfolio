---
import '../styles/global.css';
import Layout from '../components/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';

const title = 'AI Engineering Writing | Amit Upadhyay | aiwisdom.dev';
const description = 'Technical essays and guides on Azure AI, RAG, .NET, and production AI system design.';

const topics = [
  {
    title: 'Azure OpenAI in Production',
    description: 'Real-world patterns for deploying and operating Azure OpenAI at scale.',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>`,
  },
  {
    title: 'RAG Architecture Patterns',
    description: 'Retrieval-Augmented Generation pipelines — chunking, embedding, retrieval, and ranking.',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>`,
  },
  {
    title: '.NET AI Integration',
    description: 'Building AI-powered .NET applications with Semantic Kernel and Azure SDKs.',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>`,
  },
  {
    title: 'Vector Stores & Embeddings',
    description: 'Deep-dives into vector databases, embedding models, and similarity search.',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"/></svg>`,
  },
  {
    title: 'AI Agent Design',
    description: 'Autonomous agent architectures — reasoning loops, tool use, and orchestration.',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  },
  {
    title: 'Real-World Case Studies',
    description: 'Lessons from shipping AI features in production enterprise environments.',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>`,
  },
];
---

<Layout title={title} description={description}>
  <Navbar slot="navbar" />

  <!-- Hero -->
  <section class="relative pt-32 pb-16 md:pt-40 md:pb-24 overflow-hidden">
    <div class="absolute inset-0 bg-grid opacity-30"></div>
    <div class="absolute top-20 right-1/4 w-96 h-96 bg-accent/5 rounded-full blur-3xl"></div>

    <div class="relative max-w-container mx-auto px-6">
      <div class="max-w-3xl">
        <p class="text-xs font-medium text-accent uppercase tracking-widest mb-3 animate-fade-in">Writing</p>
        <h1 class="text-h1-mobile md:text-h1 text-primary animate-fade-in-up">
          Thinking in <span class="text-accent">Public</span>
        </h1>
        <p class="mt-6 text-body-lg text-secondary max-w-xl animate-fade-in-up" style="animation-delay: 0.2s;">
          Technical essays on AI engineering, Azure, and .NET systems — published at <a
            href="https://aiwisdom.dev"
            target="_blank"
            rel="noopener noreferrer"
            class="text-accent hover:text-accent-hover underline underline-offset-4 transition-colors"
          >aiwisdom.dev</a>
        </p>
      </div>
    </div>
  </section>

  <!-- Topics Grid -->
  <section class="pb-16 md:pb-24">
    <div class="max-w-container mx-auto px-6">
      <h2 class="text-h3 text-primary mb-8 reveal">Topics I Cover</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {topics.map((topic, i) => (
          <div class={`glow-card rounded-xl p-6 reveal reveal-delay-${(i % 4) + 1}`}>
            <div class="w-10 h-10 rounded-lg bg-accent/10 text-accent flex items-center justify-center mb-4" set:html={topic.icon} />
            <h3 class="text-lg font-semibold text-primary">{topic.title}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed">{topic.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="pb-24 md:pb-32">
    <div class="max-w-container mx-auto px-6">
      <div class="glow-card rounded-2xl p-10 md:p-14 text-center reveal">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 bg-accent/10 rounded-full blur-3xl pointer-events-none"></div>
        <p class="relative text-xs font-medium text-accent uppercase tracking-widest mb-4">AIWISDOM.dev</p>
        <h2 class="relative text-h2 text-primary">
          Read the <span class="text-accent">full archive</span>
        </h2>
        <p class="relative mt-4 text-body text-muted max-w-lg mx-auto">
          Every essay is written from hands-on production experience — from architecture decisions to debugging war stories.
        </p>
        <div class="relative mt-8">
          <Button href="https://aiwisdom.dev" variant="primary" external>
            Visit AIWISDOM.dev →
          </Button>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) entry.target.classList.add('visible');
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
  );
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
